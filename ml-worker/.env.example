# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Google Gemini
GEMINI_API_KEY=AIza...

# Security
CALLBACK_SECRET=change-me-to-random-secret

# ML Config
WHISPER_MODEL=medium

# Story 10.3 — Família narrativa + dim discourse_arc
# Default false: comportamento idêntico v0.7.0-calibrated-bench (AC7).
# Quando true: Gemini avalia arco macro do transcript, narrativa entra em overall_score.
NARRATIVE_FAMILY_ENABLED=false
WEIGHT_TECNICA=0.6
WEIGHT_NARRATIVA=0.4

# Logging
LOG_LEVEL=DEBUG
